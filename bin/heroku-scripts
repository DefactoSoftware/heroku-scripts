#!/usr/bin/env bash
# heroku-scripts: a thin wrapper around the heroku CLI for pipeline operations.

set -euo pipefail

SCRIPT_NAME="${0##*/}"

usage() {
  cat <<EOF
Usage: $SCRIPT_NAME <command> [args...]

Commands:
  help, --help, -h
      Show this help.

Requires the \`heroku\` CLI to be installed and authenticated.
EOF
}

main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 1
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    help|--help|-h)
      usage
      ;;
    *)
      echo "Unknown command: $cmd" >&2
      echo >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
