#!/usr/bin/env bash
# heroku-scripts: a thin wrapper around the heroku CLI for pipeline operations.

set -euo pipefail

SCRIPT_NAME="${0##*/}"
SCRIPT_VERSION="0.1.0"

# Prints a message to stderr and exits non-zero.
die() {
  echo "$*" >&2
  exit 1
}

usage() {
  cat <<EOF
Usage: $SCRIPT_NAME <command> [args...]

Commands:
  apps <pipeline> <stage>
      List apps in <pipeline>/<stage>, one per line.

  pipeline-cmd <pipeline> <stage> "<heroku command>" [--concurrency=N] [--no-stream] [-a] [--table|--csv]
      Run the given heroku command against every app in <pipeline>/<stage>,
      in chunks of N (default 3). One record per app is emitted as each app
      finishes (so output appears progressively); --no-stream withholds output
      until every app finishes and emits it sorted by app name. Apps with empty
      output are skipped (a count is reported on stderr); pass -a/--all to
      include them.

      On a terminal the output is an aligned table (\`appname | output\`);
      when piped it is CSV (\`appname;output\`). Force either with --table or
      --csv. The output field is the app's raw combined heroku output and may
      contain newlines and semicolons, so the CSV is for reading/grepping, not
      parsing as strict CSV.

  pipeline-task <pipeline> <stage> <MixTask> [--concurrency=N]
      Run \`mix <MixTask>\` via \`heroku run\` against every app in
      <pipeline>/<stage>. Defaults to 3 concurrent runs.

  promote <app> <to-team> <pipeline> [--dry-run] [--yes]
      Resize dynos to standard-1x, transfer <app> and <app>-staging
      to <to-team>, and add them to <pipeline> under production /
      staging respectively. Prompts for confirmation first (these are
      destructive, largely irreversible operations). --dry-run prints the
      heroku commands without running them; --yes skips the prompt.

  help, --help, -h
      Show this help.

  version, --version, -V
      Print the script version.

Requires the \`heroku\` CLI to be installed and authenticated.

Authentication:
  Uses HEROKU_API_KEY if set. Otherwise, if HEROKU_SCRIPTS_OP_REF holds a
  1Password secret reference, the key is read from 1Password once via \`op\`
  and reused for every call (avoids per-invocation interactive prompts):
    export HEROKU_SCRIPTS_OP_REF="op://Private/Heroku/credential"
EOF
}

# Strips ambient noise the heroku CLI prints around every invocation: the
# "heroku update available" banner, the "HEROKU_API_KEY is set" auth notice,
# and pg:psql's "--> Connecting to ..." line.
# `|| true` keeps grep's "no matches" exit from tripping `set -e`.
strip_heroku_noise() {
  grep -vE '^[[:space:]]*›[[:space:]]+Warning: heroku update available' \
    | grep -vE '^[[:space:]]*›[[:space:]]+Warning: HEROKU_API_KEY is set' \
    | grep -vE '^[[:space:]]*-->[[:space:]]+Connecting to postgresql-' \
    || true
}

# Resolves HEROKU_API_KEY from 1Password once, in the foreground, before any of
# the parallel/backgrounded heroku calls run.
#
# 1Password's heroku credential flow is interactive (a desktop approval and an
# account selector). pipeline-cmd runs heroku in backgrounded subshells whose
# stdin is /dev/null, so that prompt can't be answered and the run stalls.
# Reading the key a single time here means 1Password approves once and every
# child heroku process inherits the exported key — no per-invocation prompts.
#
# Opt in by exporting a 1Password secret reference, e.g. in your shell profile:
#   export HEROKU_SCRIPTS_OP_REF="op://Private/Heroku/credential"
# An existing HEROKU_API_KEY is left untouched, so prepending
# `HEROKU_API_KEY=... heroku-scripts ...` still works and is taken as-is.
resolve_heroku_api_key() {
  [[ -n "${HEROKU_API_KEY:-}" ]] && return 0
  local ref="${HEROKU_SCRIPTS_OP_REF:-}"
  [[ -n "$ref" ]] || return 0
  command -v op >/dev/null 2>&1 \
    || die "HEROKU_SCRIPTS_OP_REF is set but the 1Password CLI ('op') is not installed"
  HEROKU_API_KEY="$(op read "$ref")" \
    || die "Could not read the Heroku API key from 1Password ($ref)"
  export HEROKU_API_KEY
}

# Lists apps in <pipeline>/<stage>, one per line, on stdout.
#
# Parses `heroku pipelines:info <pipeline>` output, which lists apps as rows of
# `<app-name>  <stage>`. NO_COLOR=1 plus an ANSI strip keeps colorized output
# from being mistaken for app names. heroku's stderr is filtered through
# strip_heroku_noise so the update banner doesn't bleed onto the terminal.
apps_in_stage() {
  local pipeline="$1" stage="$2"
  NO_COLOR=1 heroku pipelines:info "$pipeline" 2> >(strip_heroku_noise >&2) \
    | sed -E $'s/\x1b\\[[0-9;]*m//g' \
    | awk -v stage="$stage" 'NF >= 2 && $NF == stage { print $1 }'
}

# Prints the apps in <pipeline>/<stage> on stdout, or dies if the stage has
# none. The empty-stage check lives here so every caller gets it for free.
require_apps() {
  local pipeline="$1" stage="$2" apps
  apps="$(apps_in_stage "$pipeline" "$stage")"
  [[ -n "$apps" ]] || die "No apps found in $pipeline/$stage"
  printf '%s\n' "$apps"
}

# Parses the option arguments that follow a subcommand's positional ones and
# echoes the validated concurrency (default 3) on stdout. Only --concurrency=N
# is accepted. On an unknown option or a non-positive-integer value it prints an
# error and returns 1, so callers use:
#   concurrency="$(parse_concurrency "$@")" || exit 1
parse_concurrency() {
  local concurrency=3
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --concurrency=*) concurrency="${1#*=}";;
      *) echo "Unknown option: $1" >&2; return 1;;
    esac
    shift
  done
  if [[ ! "$concurrency" =~ ^[1-9][0-9]*$ ]]; then
    echo "--concurrency must be a positive integer" >&2
    return 1
  fi
  printf '%s\n' "$concurrency"
}

cmd_apps() {
  [[ $# -eq 2 ]] || die "Usage: $SCRIPT_NAME apps <pipeline> <stage>"
  resolve_heroku_api_key
  apps_in_stage "$1" "$2"
}

# Runs a heroku command against a single app, captures combined output.
#
# Inserts `-a <app>` after the heroku args but before any `--` separator, so
# commands like `ps:exec -- some-remote-cmd` route the app flag to heroku
# rather than to the remote command.
heroku_for_app() {
  local app="$1" cmd="$2"
  if [[ " $cmd " == *" -- "* ]]; then
    # Split on the FIRST `--`: %% strips the longest ` -- *` suffix (everything
    # from the first separator on) and #* strips up to the first separator, so
    # both halves agree even when the remote command contains its own `--`.
    local before="${cmd%% -- *}"
    local after="${cmd#* -- }"
    eval "heroku $before -a \"\$app\" -- $after" 2>&1
  else
    eval "heroku $cmd -a \"\$app\"" 2>&1
  fi
}

# Runs `heroku` with the given arguments passed as a real argv array — NOT a
# string through eval — against a single app, with ambient noise stripped.
#
# Used by promote, whose team and pipeline arguments are discrete values, not a
# free-form shell command. Routing them through heroku_for_app's eval would let
# a stray space, glob character, or shell metacharacter in a pasted/mistyped
# name be word-split, glob-expanded, or executed; passing argv avoids all three.
#
# Honors $DRY_RUN: when "true" it prints the exact command (safely quoted)
# instead of executing it, so promote can preview destructive operations.
heroku_argv() {
  if [[ "${DRY_RUN:-}" == "true" ]]; then
    { printf 'would run: heroku'; printf ' %q' "$@"; printf '\n'; }
    return 0
  fi
  heroku "$@" 2>&1 | strip_heroku_noise
}

# Width of the app-name column for table rendering: the longest app name, but at
# least the header's own width. App names are known before any heroku command
# runs, so this is computed up front — which is what lets table output stream
# (the only column needing a fixed width is the left one).
app_column_width() {
  local list="$1" width=7 a   # 7 = len("appname")
  while IFS= read -r a; do
    [[ -z "$a" ]] && continue
    (( ${#a} > width )) && width=${#a}
  done <<< "$list"
  printf '%s' "$width"
}

# Prints n copies of a single character (nothing when n <= 0).
repeat_char() {
  local char="$1" n="$2"
  (( n > 0 )) || return 0
  printf '%*s' "$n" '' | tr ' ' "$char"
}

# Prints the aligned-table header and its rule. The output column is open-ended
# (no right border), so the rule just runs to the terminal width.
print_table_header() {
  local width="$1" cols=80 right
  printf '%-*s | %s\n' "$width" "appname" "output"
  # Size the rule to the terminal when stdout is one; fall back to 80 when it is
  # redirected (forced --table) or tput returns anything non-numeric.
  if [[ -t 1 ]]; then
    cols="$(tput cols 2>/dev/null || echo 80)"
    [[ "$cols" =~ ^[0-9]+$ ]] || cols=80
  fi
  right=$(( cols - width - 3 ))
  (( right < 6 )) && right=6
  printf '%s-+-%s\n' "$(repeat_char '-' "$width")" "$(repeat_char '-' "$right")"
}

# Emits one app's record in the requested format.
#   csv:   app;output  (output verbatim; may span lines / contain ';')
#   table: app padded to $width, " | ", then output. Continuation lines of a
#          multi-line output get a blank app cell so they stay aligned.
emit_record() {
  local fmt="$1" width="$2" app="$3" output="$4"
  if [[ "$fmt" != "table" ]]; then
    printf '%s;%s\n' "$app" "$output"
    return
  fi
  if [[ -z "$output" ]]; then
    printf '%-*s |\n' "$width" "$app"
    return
  fi
  # `|| break` stops on the first failed write so a vanished reader (e.g.
  # `--table | head`) doesn't keep looping with SIGPIPE ignored — that would
  # hold the streaming lock and emit one broken-pipe error per remaining line.
  local first=1 line
  while IFS= read -r line || [[ -n "$line" ]]; do
    if (( first )); then
      printf '%-*s | %s\n' "$width" "$app" "$line" || break
      first=0
    else
      printf '%-*s | %s\n' "$width" "" "$line" || break
    fi
  done <<< "$output"
}

cmd_pipeline_cmd() {
  [[ $# -ge 3 ]] || die "Usage: $SCRIPT_NAME pipeline-cmd <pipeline> <stage> \"<heroku command>\" [--concurrency=N] [--no-stream] [-a] [--table|--csv]"
  local pipeline="$1" stage="$2" command="$3"
  shift 3

  # Pull our own flags out before handing the rest to parse_concurrency (which
  # only knows --concurrency). Streaming is the default; --no-stream buffers and
  # emits everything sorted by app name at the end. Apps whose output is empty
  # are skipped by default; -a/--all includes them. Output format defaults to a
  # table on a terminal and CSV when piped; --table/--csv force one.
  local stream=true include_empty=false format=auto
  local -a opts=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --stream) stream=true;;
      --no-stream) stream=false;;
      -a|--all) include_empty=true;;
      --table) format=table;;
      --csv) format=csv;;
      *) opts+=("$1");;
    esac
    shift
  done

  local concurrency=3
  if [[ ${#opts[@]} -gt 0 ]]; then
    concurrency="$(parse_concurrency "${opts[@]}")" || exit 1
  fi

  resolve_heroku_api_key

  local apps
  apps="$(require_apps "$pipeline" "$stage")" || exit 1

  # Resolve auto -> table on a terminal, CSV when piped. The table's left column
  # is sized from the (already known) app list, so table output still streams.
  local render="$format"
  if [[ "$render" == "auto" ]]; then
    if [[ -t 1 ]]; then render=table; else render=csv; fi
  fi
  local width=7
  [[ "$render" == "table" ]] && width="$(app_column_width "$apps")"

  local tmpdir
  tmpdir="$(mktemp -d)"
  # Interpolate $tmpdir into the trap *now*, not at fire time — by the time
  # the EXIT trap runs, this function has returned and the local is gone.
  # shellcheck disable=SC2064
  trap "rm -rf '$tmpdir'" EXIT
  # On an external INT/TERM (cron, a wrapper script, plain `kill`, systemd
  # stop) the signal reaches only the parent. Without this, the backgrounded
  # heroku subshells are orphaned and keep running while the EXIT trap deletes
  # the tmpdir out from under them. Tear the jobs down first, then clean up.
  # shellcheck disable=SC2064
  trap "trap - INT TERM EXIT; kill \$(jobs -p) 2>/dev/null || true; rm -rf '$tmpdir'; exit 130" INT TERM

  # Workers drop a marker file here for each app skipped due to empty output, so
  # the parent can report a count after they all finish. A dotfile dir, so the
  # --no-stream collection glob (`$tmpdir/*`) never picks it up.
  mkdir "$tmpdir/.skipped"

  if [[ "$render" == "table" ]]; then
    print_table_header "$width"
  else
    echo "appname;output"
  fi

  # Process apps in chunks of $concurrency. Waiting for each chunk to drain
  # before starting the next caps resource use; running every app in parallel
  # has swamped laptops on large pipelines.
  #
  # The app list is fed in on FD 3 (not stdin) and each backgrounded subshell
  # has its stdin redirected to /dev/null. Without these two redirections,
  # heroku/psql in the subshell will happily read from the loop's heredoc
  # and consume the lines that the next `read` was supposed to see — apps
  # get skipped and their names get fed to heroku as stray positional args.
  local in_flight=0
  while IFS= read -r app <&3; do
    [[ -z "$app" ]] && continue
    (
      # The subshell inherits `set -e`. We deliberately turn it off here so a
      # non-zero exit from heroku (e.g. pg:psql against an app without a DB)
      # is captured into the output column rather than killing the subshell
      # before it can emit its record.
      set +e
      output="$(heroku_for_app "$app" "$command" | strip_heroku_noise)"
      if [[ -z "$output" && "$include_empty" != "true" ]]; then
        # Empty output: record the skip for the summary and emit no record.
        : > "$tmpdir/.skipped/$app"
      elif [[ "$stream" == "true" ]]; then
        # Print as soon as this app finishes. Serialize with an atomic mkdir
        # lock so a record streams out in one piece (emit_record may write
        # several lines for multi-line/table output) even when apps finish at
        # the same time; contention is brief. Ignore SIGPIPE so that if the
        # reader goes away (e.g. `| head`) the writes merely fail instead of
        # killing the worker mid-record and leaving the lock held; emit_record
        # breaks on the first failed write so the lock is released promptly.
        trap '' PIPE
        while ! mkdir "$tmpdir/.lock" 2>/dev/null; do sleep 0.05; done
        emit_record "$render" "$width" "$app" "$output"
        rmdir "$tmpdir/.lock"
      else
        # Buffered: store the raw output (filename is the app name) and format
        # it sorted at the end.
        printf '%s' "$output" > "$tmpdir/$app"
      fi
    ) </dev/null &
    # Pre-increment so the expression value (and thus exit status) is the
    # new value — post-increment would return 0 on the first iteration and
    # trip `set -e`.
    (( ++in_flight ))
    if (( in_flight >= concurrency )); then
      wait || true
      in_flight=0
    fi
  done 3<<< "$apps"
  wait || true

  # Streaming mode already printed each record. For --no-stream, emit the
  # buffered per-app rows now, in a stable app-name order. Bash sorts glob
  # matches and heroku app names contain no whitespace or glob characters, so
  # iterating the glob is deterministic — unlike `find`, whose order is
  # filesystem-dependent. The `[[ -f ]]` guard makes the no-match case a no-op
  # (the glob stays literal when $tmpdir has no app files).
  if [[ "$stream" != "true" ]]; then
    local f
    for f in "$tmpdir"/*; do
      [[ -f "$f" ]] || continue
      emit_record "$render" "$width" "${f##*/}" "$(cat "$f")"
    done
  fi

  # Report how many apps were skipped for empty output, on stderr so it never
  # pollutes the data stream piped from stdout. Separated from the output by a
  # blank line and rendered dim + italic — but only when stderr is a terminal
  # and NO_COLOR is unset, so redirected/piped output stays plain text.
  local skipped
  skipped="$(find "$tmpdir/.skipped" -type f | wc -l | tr -d ' ')"
  if (( skipped > 0 )); then
    local msg="$skipped app(s) with empty output skipped (use -a/--all to include them)"
    if [[ -t 2 && -z "${NO_COLOR:-}" ]]; then
      printf '\n\033[2;3m%s\033[0m\n' "$msg" >&2
    else
      printf '\n%s\n' "$msg" >&2
    fi
  fi
}

cmd_pipeline_task() {
  [[ $# -ge 3 ]] || die "Usage: $SCRIPT_NAME pipeline-task <pipeline> <stage> <MixTask> [--concurrency=N]"
  local pipeline="$1" stage="$2" task="$3"
  shift 3

  local concurrency
  concurrency="$(parse_concurrency "$@")" || exit 1

  resolve_heroku_api_key

  local apps
  apps="$(require_apps "$pipeline" "$stage")" || exit 1

  # Best-effort, like pipeline-cmd: a single app's failure is reported with its
  # name and does not abort the whole run. Without the wrapping `sh -c ... ||`,
  # one failing `heroku run` would make xargs exit non-zero and, under
  # `set -e`, kill the command before the remaining apps were reported. Output
  # still interleaves across concurrent runs.
  # shellcheck disable=SC2016  # $1/$2 are expanded by the inner sh, not now
  printf '%s\n' "$apps" \
    | xargs -P "$concurrency" -I {} sh -c '
        if ! heroku run -a "$1" mix "$2"; then
          echo "pipeline-task: $1 failed (mix $2)" >&2
        fi
      ' _ {} "$task"
}

cmd_promote() {
  local DRY_RUN=false assume_yes=false
  local -a positional=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) DRY_RUN=true;;
      --yes|-y) assume_yes=true;;
      --) shift; while [[ $# -gt 0 ]]; do positional+=("$1"); shift; done; break;;
      -*) die "Unknown option: $1";;
      *) positional+=("$1");;
    esac
    shift
  done

  if [[ ${#positional[@]} -ne 3 ]]; then
    die "Usage: $SCRIPT_NAME promote <app> <to-team> <pipeline> [--dry-run] [--yes]"
  fi
  local app="${positional[0]}" to_team="${positional[1]}" pipeline="${positional[2]}"
  local staging="${app}-staging"

  # Spell out exactly what is about to happen. apps:transfer in particular is
  # effectively irreversible from the sender's side, so the operator gets a
  # clear preview and an explicit confirmation before anything runs.
  {
    echo "About to promote:"
    echo "  app:      $app"
    echo "  staging:  $staging"
    echo "  team:     $to_team"
    echo "  pipeline: $pipeline"
    echo
    echo "This resizes both dynos to standard-1x, TRANSFERS ownership to team"
    echo "'$to_team' (irreversible without the receiving team transferring back),"
    echo "and adds both apps to pipeline '$pipeline'."
    echo
  } >&2

  if [[ "$DRY_RUN" != "true" && "$assume_yes" != "true" ]]; then
    local reply
    read -r -p "Proceed? [y/N] " reply || reply=""
    case "$reply" in
      y|Y|yes|Yes|YES) ;;
      *) echo "Aborted." >&2; exit 1;;
    esac
  fi

  # A dry run prints commands without calling heroku, so it needs no credential.
  [[ "$DRY_RUN" == "true" ]] || resolve_heroku_api_key

  echo "Promoting $staging and $app ->"

  echo "1. upgrading dynos to standard-1x..."
  heroku_argv dyno:resize standard-1x -a "$staging"
  heroku_argv dyno:resize standard-1x -a "$app"

  echo "2. transferring ownership to $to_team..."
  heroku_argv apps:transfer "$to_team" -a "$staging"
  heroku_argv apps:transfer "$to_team" -a "$app"

  echo "3. adding to pipeline $pipeline..."
  heroku_argv pipelines:add "$pipeline" -s staging -a "$staging"
  heroku_argv pipelines:add "$pipeline" -s production -a "$app"
}

main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 1
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    apps)
      cmd_apps "$@"
      ;;
    pipeline-cmd)
      cmd_pipeline_cmd "$@"
      ;;
    pipeline-task)
      cmd_pipeline_task "$@"
      ;;
    promote)
      cmd_promote "$@"
      ;;
    help|--help|-h)
      usage
      ;;
    version|--version|-V)
      echo "$SCRIPT_NAME $SCRIPT_VERSION"
      ;;
    *)
      echo "Unknown command: $cmd" >&2
      echo >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
