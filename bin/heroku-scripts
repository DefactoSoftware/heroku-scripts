#!/usr/bin/env bash
# heroku-scripts: a thin wrapper around the heroku CLI for pipeline operations.

set -euo pipefail

SCRIPT_NAME="${0##*/}"

usage() {
  cat <<EOF
Usage: $SCRIPT_NAME <command> [args...]

Commands:
  apps <pipeline> <stage>
      List apps in <pipeline>/<stage>, one per line.

  pipeline-cmd <pipeline> <stage> "<heroku command>"
      Run the given heroku command against every app in <pipeline>/<stage>,
      in parallel. Emits CSV-style output: \`<app>;<output>\`.

  help, --help, -h
      Show this help.

Requires the \`heroku\` CLI to be installed and authenticated.
EOF
}

# Lists apps in <pipeline>/<stage>, one per line, on stdout.
#
# Parses `heroku pipelines:info <pipeline>` output, which lists apps as rows of
# `<app-name>  <stage>`. NO_COLOR=1 plus an ANSI strip keeps colorized output
# from being mistaken for app names.
apps_in_stage() {
  local pipeline="$1" stage="$2"
  NO_COLOR=1 heroku pipelines:info "$pipeline" \
    | sed -E $'s/\x1b\\[[0-9;]*m//g' \
    | awk -v stage="$stage" 'NF >= 2 && $NF == stage { print $1 }'
}

cmd_apps() {
  if [[ $# -ne 2 ]]; then
    echo "Usage: $SCRIPT_NAME apps <pipeline> <stage>" >&2
    exit 1
  fi
  apps_in_stage "$1" "$2"
}

# Runs a heroku command against a single app, captures combined output.
#
# Inserts `-a <app>` after the heroku args but before any `--` separator, so
# commands like `ps:exec -- some-remote-cmd` route the app flag to heroku
# rather than to the remote command.
heroku_for_app() {
  local app="$1" cmd="$2"
  if [[ " $cmd " == *" -- "* ]]; then
    local before="${cmd% -- *}"
    local after="${cmd#* -- }"
    eval "heroku $before -a \"\$app\" -- $after" 2>&1
  else
    eval "heroku $cmd -a \"\$app\"" 2>&1
  fi
}

cmd_pipeline_cmd() {
  if [[ $# -ne 3 ]]; then
    echo "Usage: $SCRIPT_NAME pipeline-cmd <pipeline> <stage> \"<heroku command>\"" >&2
    exit 1
  fi
  local pipeline="$1" stage="$2" command="$3"

  local apps
  apps="$(apps_in_stage "$pipeline" "$stage")"
  if [[ -z "$apps" ]]; then
    echo "No apps found in $pipeline/$stage" >&2
    exit 1
  fi

  local tmpdir
  tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' EXIT

  echo "appname;output"
  while IFS= read -r app; do
    [[ -z "$app" ]] && continue
    (
      output="$(heroku_for_app "$app" "$command")"
      printf '%s;%s\n' "$app" "$output" > "$tmpdir/$app"
    ) &
  done <<< "$apps"
  wait

  cat "$tmpdir"/*
}

main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 1
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    apps)
      cmd_apps "$@"
      ;;
    pipeline-cmd)
      cmd_pipeline_cmd "$@"
      ;;
    help|--help|-h)
      usage
      ;;
    *)
      echo "Unknown command: $cmd" >&2
      echo >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
